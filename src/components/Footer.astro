---
import Button from "./Button.astro"
import FooterMenuLink from "./FooterMenuLink.astro"

const { page } = Astro.props;
---

<footer>
  <div class="flex flex-col md:flex-row justify-between xl:items-center gap-32 px-32 md:px-53 lg:px-59 py-53 py:lg-95 bg-charcoal">
    <div class="flex flex-col gap-22 lg:gap-14">
      <div class="flex flex-col items-center md:items-start gap-12 lg:gap-14">
        <a href="/" class="w-249 lg:w-359">
          <img fetchpriority="high" src="/images/webcharged-logo.svg" alt="Go to WebCharged Home" width="359" height="95"/>
        </a>
        <p class="text-electric lg:text-21 font-semibold text-center">Grow your profits; Gain a partnership.</p>
      </div>
      <div class="hidden md:flex flex-col gap-22">
        <div class="flex flex-col gap-9">
          <p><a class="text-electric underline hover:text-parchment focus:text-parchment focus-visible:text-parchment active:text-parchment" href="tel:928-235-2131">
            928-235-2131
          </a></p>
          <p><a class="text-electric underline hover:text-parchment focus:text-parchment focus-visible:text-parchment active:text-parchment" href="mailto:hello@webchargedsolutions.com">
            hello@webchargedsolutions.com
          </a></p>
          <p class="text-electric"><span class="font-semibold">Business Hours:</span> 7AM - 3PM, Tuesday - Saturday </p>
        </div>
        <Button class="self-start" link="/project-planning-call">Book a call today!</Button>
      </div>
    </div>

    <nav class="flex flex-col xl:flex-row gap-22 md:gap-5 xl:gap-59">
      <div class="flex flex-col gap-5 xl:gap-9">
        <FooterMenuLink aria-current={page === "home" ? "page" : undefined} link="/">Home</FooterMenuLink>
        <FooterMenuLink aria-current={page === "about-us" ? "page" : undefined} link="/about-us">About Us</FooterMenuLink>
        <FooterMenuLink aria-current={page === "contact-us" ? "page" : undefined} link="/contact-us">Contact Us</FooterMenuLink>
      </div>
      <div class="flex flex-col gap-5 xl:gap-9">
        <FooterMenuLink aria-current={page === "custom-website-design" ? "page" : undefined} link="/custom-website-design">Website Design & Development</FooterMenuLink>
        <FooterMenuLink aria-current={page === "website-support-plans" ? "page" : undefined} link="/website-support-plans">Website Support</FooterMenuLink>
        <FooterMenuLink link="https://g.page/r/CXHisG7xbBjDEAE/review" target="_blank">Review Us</FooterMenuLink>
      </div>
      <div class="flex flex-col gap-5 xl:gap-9">
        <FooterMenuLink aria-current={page === "frequently-asked-questions" ? "page" : undefined} link="/frequently-asked-questions">FAQ</FooterMenuLink>
        <FooterMenuLink aria-current={page === "privacy-policy" ? "page" : undefined} link="/privacy-policy">Privacy Policy</FooterMenuLink>
        <FooterMenuLink aria-current={page === "terms-and-conditions" ? "page" : undefined} link="/terms-and-conditions">Terms & Conditions</FooterMenuLink>
      </div>
    </nav>

    <div class="flex flex-col md:hidden gap-9">
      <p><a class="text-electric underline hover:text-parchment focus:text-parchment focus-visible:text-parchment active:text-parchment" href="tel:928-235-2131">
        928-235-2131
      </a></p>
      <p><a class="text-electric underline hover:text-parchment focus:text-parchment focus-visible:text-parchment active:text-parchment" href="mailto:hello@webchargedsolutions.com">
        hello@webchargedsolutions.com
      </a></p>
      <p class="text-electric"><span class="font-semibold">Business Hours:</span> <br class="md:hidden" />7AM - 3PM, Tuesday - Saturday </p>
    </div>
    <Button class="self-start md:hidden" link="/project-planning-call">Book a call today!</Button>

  </div>
  <div class="flex flex-col-reverse md:flex-row md:flex-wrap-reverse justify-between items-center gap-x-53 gap-y-20 md:gap-y-12 px-44 md:px-53 lg:px-59 py-20 lg:py-22 bg-spark">
    <div>
      <p class="font-semibold text-center">2026 WebCharged Web Solutions LLC — All rights reserved.</p>
    </div>
    <div class="flex flex-col md:flex-row gap-9 md:gap-22 items-center">
      <a href="/cookie-policy" class="font-semibold underline leading-[175%] hover:no-underline focus:no-underline focus-visible:no-underline active:no-underline">
        Cookie Policy
      </a>
      <a href="/" class="font-semibold underline leading-[175%] hover:no-underline focus:no-underline focus-visible:no-underline active:no-underline">
        Cookie Settings
      </a>
      <a href="/disclaimer" class="font-semibold underline leading-[175%] hover:no-underline focus:no-underline focus-visible:no-underline active:no-underline">
        Disclaimer
      </a>
    </div>
  </div>
</footer>